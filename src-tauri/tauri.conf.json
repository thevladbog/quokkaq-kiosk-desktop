{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuokkaQ Kiosk",
  "version": "0.1.1",
  "identifier": "com.quokkaq.kiosk",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "QuokkaQ Kiosk",
        "width": 1280,
        "height": 800,
        "url": "splash.html",
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/quokkaq-kiosk-agent"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
